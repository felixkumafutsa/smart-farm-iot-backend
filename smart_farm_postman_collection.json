{
    "info": {
        "_postman_id": "smart-farm-iot-collection-v3",
        "name": "Smart Farm Cloud API (Vercel Ready)",
        "description": "Production-ready collection for Smart Farm IoT. Includes automated variable syncing for Device Keys, Agent Keys, and JWT tokens.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth & Admin",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.token) {",
                                    "    pm.collectionVariables.set(\"jwtToken\", jsonData.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Register Agent",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.agent && jsonData.agent.api_key) {",
                                    "    pm.collectionVariables.set(\"agentApiKey\", jsonData.agent.api_key);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Smart-AI-Agent\",\n  \"permissions\": [\"read_telemetry\", \"send_commands\"]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register-agent",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register-agent"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Devices",
            "item": [
                {
                    "name": "Register Device",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.device && jsonData.device.api_key) {",
                                    "    pm.collectionVariables.set(\"deviceApiKey\", jsonData.device.api_key);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"device_id\": \"farm-node-01\",\n  \"location\": \"Blantyre Farm\",\n  \"latitude\": -15.7861,\n  \"longitude\": 35.0058\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/devices/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "devices",
                                "register"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "IoT Data (ESP32 Simulation)",
            "item": [
                {
                    "name": "Send Sensor Data",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "x-api-key",
                                "value": "{{deviceApiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"device_id\": \"farm-node-01\",\n  \"temperature\": 27.5,\n  \"humidity\": 68,\n  \"soil_moisture\": 35,\n  \"light_intensity\": 75,\n  \"latitude\": -15.7861,\n  \"longitude\": 35.0058\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/iot/data",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "iot",
                                "data"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Agent API (Third-Party)",
            "item": [
                {
                    "name": "Get All Devices",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "x-agent-key",
                                "value": "{{agentApiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/agent/devices",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "agent",
                                "devices"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get AI Analysis (Summaries)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "x-agent-key",
                                "value": "{{agentApiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"device_id\": \"farm-node-01\",\n  \"query_type\": \"averages\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/agent/query",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "agent",
                                "query"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "https://smart-farm-iot-backend.vercel.app",
            "type": "string"
        },
        {
            "key": "jwtToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "deviceApiKey",
            "value": "",
            "type": "string"
        },
        {
            "key": "agentApiKey",
            "value": "",
            "type": "string"
        }
    ]
}