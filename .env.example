# MongoDB Connection String (Atlas highly recommended for production)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smart_farm_db

# Auth Secrets
JWT_SECRET=your_production_secret_key_change_me
JWT_EXPIRES_IN=30d

# Optional: Admin Credentials for Seeding
ADMIN_USER=admin
ADMIN_PASS=password123

# Server Config
NODE_ENV=production
